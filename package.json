{
  "name": "living-atlas",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.8.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "check": "npm run lint:repo-safety && npm run typecheck && npm test",
    "cloudflare:live-concurrency-smoke": "tsx packages/check/src/cloudflare-live-concurrency-smoke.ts",
    "cloudflare:live-cloud-unlock-proof": "tsx packages/check/src/cloudflare-live-cloud-unlock-proof.ts",
    "cloudflare:live-bidirectional-sync": "tsx packages/check/src/cloudflare-live-bidirectional-sync.ts",
    "cloudflare:live-local-outbox-drain": "LIVING_ATLAS_LIVE_BIDIRECTIONAL_SYNC_MODE=drain tsx packages/check/src/cloudflare-live-bidirectional-sync.ts",
    "cloudflare:live-local-mcp-outbox-proof": "tsx packages/check/src/cloudflare-live-local-mcp-outbox-proof.ts",
    "cloudflare:live-crud-stress": "tsx packages/check/src/cloudflare-live-crud-stress.ts",
    "cloudflare:live-crud-tiny": "tsx packages/check/src/cloudflare-live-crud-tiny.ts",
    "cloudflare:live-local-sync": "tsx packages/check/src/cloudflare-live-local-sync.ts",
    "cloudflare:live-mcp-tiny": "tsx packages/check/src/cloudflare-live-mcp-tiny.ts",
    "cloudflare:live-ops-report": "tsx packages/check/src/cloudflare-live-ops-report.ts",
    "cloudflare:live-usage-gate": "tsx packages/check/src/cloudflare-live-usage-gate.ts",
    "cloudflare:local-smoke": "tsx packages/check/src/local-smoke.ts",
    "cloudflare:wrangler-smoke": "tsx packages/check/src/cli.ts wrangler-local-runtime",
    "infra:fmt": "terraform fmt -check -recursive infra/cloudflare",
    "infra:validate": "terraform -chdir=infra/cloudflare/examples/single-authority init -backend=false -input=false && terraform -chdir=infra/cloudflare/examples/single-authority validate",
    "local-control:fixture-store": "tsx packages/local-control-store/src/create-fixture.ts",
    "local-keyring:fixture-store": "tsx packages/local-keyring/src/create-fixture.ts",
    "local:deploy-synthetic": "tsx packages/check/src/local-deploy-synthetic.ts",
    "logseq:semantic-ledger-report": "tsx packages/check/src/logseq-semantic-ledger-report.ts",
    "logseq:semantic-manifest": "tsx packages/check/src/logseq-semantic-manifest.ts",
    "logseq:semantic-estimate": "tsx packages/check/src/logseq-semantic-estimate.ts",
    "logseq:semantic-inventory": "tsx packages/check/src/logseq-semantic-inventory.ts",
    "logseq:semantic-batch-plan": "tsx packages/check/src/logseq-semantic-batch-plan.ts",
    "logseq:semantic-review-report": "tsx packages/check/src/logseq-semantic-review-report.ts",
    "logseq:semantic-review-packet": "tsx packages/check/src/logseq-semantic-review-packet.ts",
    "logseq:semantic-topic-review-packet": "tsx packages/check/src/logseq-semantic-topic-review-packet.ts",
    "logseq:semantic-topic-review-report": "tsx packages/check/src/logseq-semantic-topic-review-report.ts",
    "logseq:semantic-topic-review-local": "tsx packages/check/src/logseq-semantic-topic-review-local-import.ts",
    "logseq:semantic-review-rekey": "tsx packages/check/src/logseq-semantic-review-resolution-rekey.ts",
    "logseq:semantic-knowledge-report": "tsx packages/check/src/logseq-semantic-knowledge-report.ts",
    "logseq:semantic-local": "LIVING_ATLAS_LOGSEQ_SEMANTIC_SYNC_MODE=local-only tsx packages/check/src/logseq-semantic-parity.ts",
    "logseq:semantic-cloudflare": "LIVING_ATLAS_LOGSEQ_SEMANTIC_SYNC_MODE=cloudflare tsx packages/check/src/logseq-semantic-parity.ts",
    "logseq:semantic-backfill": "LIVING_ATLAS_LOGSEQ_SEMANTIC_SYNC_MODE=backfill tsx packages/check/src/logseq-semantic-parity.ts",
    "logseq:semantic-parity": "tsx packages/check/src/logseq-semantic-parity.ts",
    "logseq:semantic-corpus-report": "tsx packages/check/src/logseq-semantic-corpus-report.ts",
    "connector:enrichment-report": "tsx packages/check/src/connector-enrichment-report.ts",
    "connector:enrichment-local": "tsx packages/check/src/connector-enrichment-local-import.ts",
    "connector:enrichment-corpus-report": "tsx packages/check/src/connector-enrichment-corpus-report.ts",
    "connector:coverage-report": "tsx packages/check/src/connector-coverage-report.ts",
    "real-data:readiness": "tsx packages/check/src/real-data-readiness.ts",
    "stress:local": "tsx packages/check/src/local-stress.ts",
    "local:install-smoke": "tsx packages/check/src/local-install-smoke.ts",
    "local-mcp:fixture": "tsx packages/local-mcp/src/cli.ts",
    "mcp:inspect:local": "npx @modelcontextprotocol/inspector npx tsx packages/local-mcp/src/cli.ts",
    "lint:repo-safety": "tsx packages/check/src/cli.ts",
    "preflight:synthetic": "npm run check && npm run local:deploy-synthetic && npm run stress:local && npm run cloudflare:wrangler-smoke && npm run infra:fmt && npm run infra:validate",
    "smoke:local": "npm run local:install-smoke && npm run cloudflare:local-smoke",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "4.20260621.1",
    "@types/node": "26.0.0",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "vitest": "4.1.9",
    "zod": "4.4.3"
  }
}
